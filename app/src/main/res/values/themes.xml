<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme (No action bar — using custom bottom nav) -->
    <style name="Theme.JobPortal" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Use our defined primary brand color -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryVariant">@color/colorPrimary</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary / accent brand color -->
        <item name="colorSecondary">@color/colorAccent</item>
        <item name="colorSecondaryVariant">@color/colorAccent</item>
        <item name="colorOnSecondary">@color/white</item>
        <!-- Status bar matches primary -->
        <item name="android:statusBarColor">@color/colorPrimary</item>
    </style>
</resources>
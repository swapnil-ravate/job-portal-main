<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Company Name -->
        <TextView
            android:id="@+id/CompanyNameTv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Company Name"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/colorPrimary"
            android:layout_marginBottom="4dp" />

        <!-- Job Title -->
        <TextView
            android:id="@+id/JobTitleTv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Job Title"
            android:textSize="18sp"
            android:textColor="#333333"
            android:layout_marginBottom="12dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginBottom="12dp" />

        <!-- Salary -->
        <TextView
            android:id="@+id/JobSalaryTv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Salary: --"
            android:textSize="14sp"
            android:textColor="#555555"
            android:layout_marginBottom="8dp" />

        <!-- Start Date -->
        <TextView
            android:id="@+id/JobStartDateTv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Start Date: --"
            android:textSize="14sp"
            android:textColor="#555555"
            android:layout_marginBottom="8dp" />

        <!-- Last Date -->
        <TextView
            android:id="@+id/JobLastDateTv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Apply By: --"
            android:textSize="14sp"
            android:textColor="#555555"
            android:layout_marginBottom="8dp" />

        <!-- Total Openings -->
        <TextView
            android:id="@+id/TotalOpeningsTv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Openings: --"
            android:textSize="14sp"
            android:textColor="#555555"
            android:layout_marginBottom="12dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginBottom="12dp" />

        <!-- About Job -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="About this Job"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/AboutJobTv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="--"
            android:textSize="14sp"
            android:textColor="#555555"
            android:layout_marginBottom="12dp" />

        <!-- Skills Required -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Skills Required"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/SkillsRequiredTv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="--"
            android:textSize="14sp"
            android:textColor="#555555"
            android:layout_marginBottom="12dp" />

        <!-- Additional Info -->
        <TextView
            android:id="@+id/AdditionalInfoTv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="14sp"
            android:textColor="#777777"
            android:layout_marginBottom="16dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginBottom="16dp" />

        <!-- ProgressBar -->
        <ProgressBar
            android:id="@+id/ProgressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginBottom="8dp"
            android:visibility="invisible" />

        <!-- Select Resume Button -->
        <Button
            android:id="@+id/SelectResumeBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select Resume (PDF)"
            android:backgroundTint="@color/colorAccent"
            android:textColor="@color/white"
            android:layout_marginBottom="8dp" />

        <!-- Selected file name -->
        <TextView
            android:id="@+id/SelectedFileNameTv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="13sp"
            android:textColor="#4CAF50"
            android:layout_marginBottom="8dp"
            android:visibility="gone" />

        <!-- Apply Button -->
        <Button
            android:id="@+id/ApplyBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Apply Now"
            android:backgroundTint="@color/colorPrimary"
            android:textColor="@color/white"
            android:layout_marginBottom="32dp" />

    </LinearLayout>
</ScrollView>

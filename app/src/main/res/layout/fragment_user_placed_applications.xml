<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="@drawable/jobi"
    tools:ignore="HardcodedText"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Message displayed when there are no applications placed -->
    <TextView
        android:id="@+id/noApplicationsMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:text="No applications placed yet"
        android:textAlignment="center"
        android:textSize="16sp"
        android:textColor="#FF0000" />

    <!-- RecyclerView for displaying selected applications -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/UserPlacedApplicationsRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"/>
</LinearLayout>
